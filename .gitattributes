# Git attributes for cross-platform compatibility
# Ensures proper handling of line endings and file encodings

# Auto detect text files and normalize to LF on checkin, platform-native on checkout
* text=auto

# Python source files should always use LF line endings
*.py text eol=lf encoding=utf-8
*.pyw text eol=lf encoding=utf-8

# Documentation files
*.md text eol=lf encoding=utf-8
*.txt text eol=lf encoding=utf-8
*.rst text eol=lf encoding=utf-8

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# Windows scripts should use CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Configuration files
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.ini text eol=lf
*.cfg text eol=lf

# Database files (binary)
*.db binary
*.sqlite binary
*.sqlite3 binary

# Excel files (binary)
*.xls binary
*.xlsx binary
*.xlsm binary

# Images (binary)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary

# Archives (binary)
*.zip binary
*.tar binary
*.gz binary
*.bz2 binary
*.7z binary

# Prevent Python cache files from being tracked
__pycache__/ export-ignore
*.pyc export-ignore
*.pyo export-ignore
*.pyd export-ignore
.Python export-ignore
